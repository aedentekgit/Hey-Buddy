# =============================================================================
# Buddy Backend — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env or any .env.* file to git.
# =============================================================================

PORT=5001

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# MongoDB connection string. For production, use TLS:
#   mongodb+srv://user:password@host:27017/dbname?authSource=admin
MONGODB_URI=mongodb://user:password@localhost:27017/staging_Heybuddy?authSource=admin

# Enable TLS for production MongoDB connections (set to 'true' for Atlas/self-hosted TLS)
MONGODB_TLS=false

# -----------------------------------------------------------------------------
# Authentication
# -----------------------------------------------------------------------------
# JWT secret for signing tokens. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change_me_to_a_long_random_secret

NODE_ENV=development

# -----------------------------------------------------------------------------
# URLs
# -----------------------------------------------------------------------------
FRONTEND_URL=http://localhost:3000
FRONTEND_URL_ALT=http://localhost:5173
BACKEND_URL=http://localhost:5001
API_URL=http://localhost:5001/api

# AI Service (Python FastAPI) URL
AI_SERVICE_URL=http://localhost:8000

# Allowed CORS origins (comma-separated, no spaces)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:5001,http://localhost:8000

# Google OAuth redirect URI
GOOGLE_REDIRECT_URI=http://localhost:5001/api/voice/google/callback

# -----------------------------------------------------------------------------
# Internal Service-to-Service Auth
# -----------------------------------------------------------------------------
# Shared secret for Python → Node and Node → Python authentication.
# Both services MUST use the SAME value.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
INTERNAL_SECRET=change_me_to_a_long_random_secret

# Development only: disable JWT auth on socket connections.
# NEVER set this to true in production or staging!
DISABLE_AUTH=false

# -----------------------------------------------------------------------------
# Body Size Limits (optional)
# -----------------------------------------------------------------------------
JSON_BODY_LIMIT=5mb
FORM_BODY_LIMIT=5mb