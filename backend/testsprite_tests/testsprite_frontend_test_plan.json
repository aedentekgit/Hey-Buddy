  {
    "id": "TC007",
    "title": "Create a reminder with title, date/time, and optional notes",
    "description": "Verifies an authenticated user can create a reminder and see it appear in the reminders list.",
    "category": "Reminder System",
    "priority": "High",
    "steps": [
      {
        "type": "action",
        "description": "Navigate to /login"
      },
      {
        "type": "action",
        "description": "Type \"{{LOGIN_USER}}\" into the username/email field"
      },
      {
        "type": "action",
        "description": "Type \"{{LOGIN_PASSWORD}}\" into the password field"
      },
      {
        "type": "action",
        "description": "Click on the \"Login\" button"
      },
      {
        "type": "assertion",
        "description": "Verify URL contains \"/api/reminders\""
      },
      {
        "type": "action",
        "description": "Click on the \"Create Reminder\" button"
      },
      {
        "type": "action",
        "description": "Type \"Take medication\" into the title field"
      },
      {
        "type": "action",
        "description": "Type \"2030-01-15 09:00\" into the date/time field"
      },
      {
        "type": "action",
        "description": "Type \"With breakfast\" into the notes field"
      },
      {
        "type": "action",
        "description": "Click on the \"Save\" button"
      },
      {
        "type": "assertion",
        "description": "Verify text \"Take medication\" is visible"
      }
    ]
  },
