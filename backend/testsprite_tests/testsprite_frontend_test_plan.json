[
  {
    "id": "TC001",
    "title": "Register a new user with valid details and reach the post-registration landing page",
    "description": "Verifies that a user can successfully register with valid inputs and is redirected to the next screen after registration.",
    "category": "User Authentication",
    "priority": "High",
    "steps": [
      {
        "type": "action",
        "description": "Navigate to /api/auth/register"
      },
      {
        "type": "assertion",
        "description": "Verify text \"Register\" is visible"
      },
      {
        "type": "action",
        "description": "Type \"Test User\" into the name field"
      },
      {
        "type": "action",
        "description": "Type \"test.user.unique+1@example.com\" into the email field"
      },
      {
        "type": "action",
        "description": "Type \"ValidPass123!\" into the password field"
      },
      {
        "type": "action",
        "description": "Click on \"Register\""
      },
      {
        "type": "assertion",
        "description": "Verify text \"Welcome\" is visible"
      },
      {
        "type": "assertion",
        "description": "Verify URL contains \"onboarding\""
      }
    ]
  },
