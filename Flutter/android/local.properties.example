# Flutter Android Local Configuration
# Copy this file to local.properties and fill in your actual values
# DO NOT commit local.properties to git!

# Google Maps API Key
# Get from: https://console.cloud.google.com/google/maps-apis
GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY_HERE

# Android Release Keystore Configuration
# Generate keystore with: keytool -genkey -v -keystore upload-keystore.jks -keyalg RSA -keysize 2048 -validity 10000 -alias upload
storeFile=upload-keystore.jks
storePassword=YOUR_STRONG_PASSWORD_HERE
keyAlias=upload
keyPassword=YOUR_KEY_PASSWORD_HERE
