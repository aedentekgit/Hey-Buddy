# Dependencies
node_modules/
package-lock.json
yarn.lock

# Environment Variables — ALL env files with real secrets must be excluded
.env
.env.local
.env.production
.env.staging
.env.development
.env.*.local
ai-service/.env
ai-service/.env.production
ai-service/.env.staging
frontend/.env
frontend/.env.production
frontend/.env.staging

# Build outputs
dist/
build/
*.log

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Database
*.db
*.sqlite

# Uploads
backend/uploads/*
!backend/uploads/.gitkeep

# Temporary files
tmp/
temp/
*.tmp

# Backup files (never commit editor/code backups)
*.bak
*.orig

# ML / FAISS binary files
*.faiss
*.pkl

# Service Account Keys (sensitive)
backend/service-account.json
backend/*.json
!backend/package.json

# Debug
ai_debug.txt

# Large Binaries
*.apk
*.ipa
*.docx
*.doc
*.pdf

# Python generated
__pycache__/
*.py[cod]
*$py.class
